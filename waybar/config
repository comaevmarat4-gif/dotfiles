{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "pulseaudio", "network", "battery", "tray"],

    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate"
    },
    "clock": {
        "format": "ΎΑΩ {:%H:%M  ΎΒ│ %d.%m.%y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "format": "ΎΜδ {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ΎΔΚ {}%"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "Ύγσ Muted",
        "format-icons": { "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"] },
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "ΎΘτ {essid}",
        "format-disconnected": "έγι Disconnected"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "tray": {
        "spacing": 10
    }
}